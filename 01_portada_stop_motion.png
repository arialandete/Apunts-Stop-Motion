/* Estil propi per als apunts de Stop Motion */

:root {
  --md-primary-fg-color: #d35400;
  --md-accent-fg-color: #f39c12;
}

.md-typeset h1 {
  color: #b54100;
  font-weight: 700;
}

.md-typeset h2 {
  color: #8f3b00;
  border-bottom: 2px solid #f2c078;
  padding-bottom: .25rem;
}

.md-typeset blockquote {
  border-left: 4px solid #f39c12;
  background: #fff7e6;
  padding: .6rem 1rem;
}

.md-typeset table:not([class]) th {
  background: #fff0d6;
}

.md-typeset img {
  border-radius: 12px;
}

.stop-card {
  background: #fff8ed;
  border: 1px solid #f1c27d;
  border-radius: 14px;
  padding: 1rem;
  margin: 1rem 0;
}
